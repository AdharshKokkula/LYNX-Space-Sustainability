{
    "provider": "huggingface",
    "model_name": "mistralai/Mistral-7B-Instruct-v0.2",
    "fallback_models": [
        "HuggingFaceH4/zephyr-7b-beta",
        "meta-llama/Llama-2-7b-chat-hf"
    ],
    "parameters": {
        "max_tokens": 1500,
        "temperature": 0.7,
        "top_p": 0.9
    },
    "retry_config": {
        "max_retries": 2,
        "backoff_factor": 2,
        "timeout_seconds": 30
    },
    "cache_config": {
        "enabled": true,
        "max_size": 100,
        "ttl_seconds": 3600
    },
    "report_config": {
        "include_mission_info": true,
        "include_recommendations": true,
        "risk_thresholds": {
            "high": 10,
            "medium": 100
        }
    }
}
